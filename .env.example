# ---- Shopify (custom app, READ-ONLY Admin API) ----
# In your Shopify admin: Settings > Apps and sales channels > Develop apps >
# Create an app > Configure Admin API scopes: read_orders, read_products >
# Install app > reveal the Admin API access token.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01

# ---- Config persistence (Vercel KV / Upstash Redis) ----
# On Vercel: Storage > Create > KV (Upstash). It auto-injects KV_REST_API_URL/TOKEN.
# Locally, paste an Upstash Redis REST URL + token. If omitted, the app falls back
# to a non-persistent in-memory store (fine for local dev, resets on restart).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Upstash-native var names are also accepted as a fallback:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
